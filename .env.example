# StaffAI Bot configuration template
# Copy to .env and update values.

# ================================
# DISCORD
# ================================
# PRODUCTION: set as Docker secret named 'discord_bot_token'
#   echo "your_token" | docker secret create discord_bot_token -


# ================================
# LOGGING
# ================================
# Log verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ================================
# GEMINI
# ================================
# Gemini model name
GEMINI_MODEL=gemini-3.1-flash-lite-preview
# PRODUCTION: set as Docker secret named 'gemini_api_key'
#   echo "your_key" | docker secret create gemini_api_key -

# Optional MCP server URLs (comma-separated)
MCP_SERVERS=

# ================================
# BOT BEHAVIOR
# ================================
# Random engagement chance on non-mention messages (0.0-1.0)
RESPONSE_CHANCE=0.05
# Bot name alias(es) to detect after direct interactions (comma-separated, case-insensitive)
BOT_NAME_TRIGGER=staffai
# Number of subsequent user messages to watch for BOT_NAME_TRIGGER after mention/reply/name interaction
BOT_NAME_FOLLOWUP_WINDOW_MESSAGES=6
# Max Redis history messages per user/channel context
MAX_HISTORY_PER_USER=20
# Max history messages injected when tools are enabled
LLM_TOOL_HISTORY_LIMIT=4

# ================================
# CONTEXT / AUDIT LIMITS
# ================================
# Redis TTL for stored conversation history (seconds, 0 = no TTL)
CONTEXT_HISTORY_TTL_SECONDS=1800
# Maximum age of context messages considered for prompts (seconds, 0 = no age filter)
CONTEXT_MESSAGE_MAX_AGE_SECONDS=1800
# Number of recent messages fetched for default context assembly
DEFAULT_CONTEXT_MESSAGES=5
# Max messages saved per LLM audit context payload
LLM_AUDIT_CONTEXT_MAX_MESSAGES=40
# Max chars per message in LLM audit context payload
LLM_AUDIT_CONTEXT_MAX_CHARS=1200

# ================================
# REDIS
# ================================
# Redis host
REDIS_HOST=localhost
# Redis port
REDIS_PORT=6379
# Redis database index
REDIS_DB=0
# Redis password (optional, leave empty if not needed)
REDIS_PASSWORD=

# ================================
# RATE LIMITING / RESTRICTIONS
# ================================
# Max message count per user in rate-limit window
RATE_LIMIT_COUNT=15
# Rate-limit window in seconds
RATE_LIMIT_WINDOW_SECONDS=60
# Max token usage per user in rate-limit window
TOKEN_RATE_LIMIT_COUNT=20000
# Role assigned to restricted users
RESTRICTED_USER_ROLE_ID=
# Channel where restricted users can interact
RESTRICTED_CHANNEL_ID=
# Restriction duration in seconds (0 disables auto-expiry)
RESTRICTION_DURATION_SECONDS=86400
# Restriction expiry check interval in seconds
RESTRICTION_CHECK_INTERVAL_SECONDS=300
# User-facing message when message-rate limit triggers
RATE_LIMIT_MESSAGE_USER="You've sent messages too frequently. Please use <#{channel_id}> for bot interactions."
# User-facing message when restricted user writes in wrong channel
RESTRICTED_CHANNEL_MESSAGE_USER="As a restricted user, please use <#{channel_id}> for bot interactions."

# ================================
# ROLE CONTROL
# ================================
# Roles that bypass limits/admin checks (comma-separated role IDs)
SUPER_ROLE_IDS=
# Roles ignored by the bot (comma-separated role IDs)
IGNORED_ROLE_IDS=
# Send super-user debug context by DM
DEBUG_CONTEXT_SUPER_USERS=False

# ================================
# ACTIVITY / PRESENCE
# ================================
# Presence refresh interval in seconds
ACTIVITY_UPDATE_INTERVAL_SECONDS=300
# Enable scheduled active-hours behavior
ACTIVITY_SCHEDULE_ENABLED=False
# UTC start hour for active schedule (0-23)
ACTIVITY_ACTIVE_START_HOUR_UTC=0
# UTC end hour for active schedule (0-23)
ACTIVITY_ACTIVE_END_HOUR_UTC=23
# Active UTC weekdays (0=Mon ... 6=Sun)
ACTIVITY_ACTIVE_DAYS_UTC=0,1,2,3,4,5,6

# ================================
# DAILY TOPIC WORKFLOW
# ================================
# Enable daily topic generation/approval workflow
DAILY_TOPIC_ENABLED=False
# Channel ID for admin approval embed
DAILY_TOPIC_APPROVAL_CHANNEL_ID=
# Forum/media channel ID where approved topic is published
DAILY_TOPIC_PUBLISH_CHANNEL_ID=
# Generation interval seconds (0 = daily mode)
DAILY_TOPIC_INTERVAL_SECONDS=0
# Daily mode approval hour in UTC
DAILY_TOPIC_APPROVAL_HOUR_UTC=8
# Auto-publish timeout for pending topic (seconds)
DAILY_TOPIC_APPROVAL_TIMEOUT_SECONDS=14400
# Scheduler tick interval (seconds)
DAILY_TOPIC_CHECK_INTERVAL_SECONDS=60
# Daily-topic thread context size (message count)
DAILY_TOPIC_THREAD_CONTEXT_MESSAGES=40
# Auto-archive for the approval thread metadata channel
DAILY_TOPIC_THREAD_AUTO_ARCHIVE_MINUTES=1440
# Title for approval embed
DAILY_TOPIC_EMBED_TITLE=Topic of the day
# Auto-archive duration for published forum post thread (60,1440,4320,10080)
DAILY_TOPIC_POST_AUTO_ARCHIVE_MINUTES=10080
# Slowmode seconds for published forum post thread
DAILY_TOPIC_POST_SLOWMODE_SECONDS=0

# ================================
# USER MEMORY
# ================================
# Enable user-memory pipeline
USER_MEMORY_ENABLED=True
# Sampling chance after pre-filters (0.0-1.0)
USER_MEMORY_UPDATE_CHANCE=0.25
# Minimum message chars to consider for memory
USER_MEMORY_MIN_MESSAGE_CHARS=50
# Minimum message words to consider for memory
USER_MEMORY_MIN_MESSAGE_WORDS=10
# Max compact memory size per user
USER_MEMORY_MAX_CHARS=420
# Pipeline mode: tiny_extract | frontier_pipeline | tiny_gate_frontier_core | disabled
USER_MEMORY_PIPELINE_MODE=tiny_gate_frontier_core
# Ollama base URL for tiny models
USER_MEMORY_OLLAMA_BASE_URL=http://localhost:11434
# Ollama API key for OpenAI-compatible endpoint
# PRODUCTION: set as Docker secret named 'user_memory_ollama_api_key' (default: "ollama")
# LOCAL DEV only:
USER_MEMORY_OLLAMA_API_KEY=ollama
# Timeout in seconds for tiny-model calls
USER_MEMORY_OLLAMA_TIMEOUT_S=30
# Default tiny model name
USER_MEMORY_TINY_MODEL=SmolLM2-1.7B-Instruct
# Optional override tiny model for extract stage
USER_MEMORY_TINY_MODEL_EXTRACT=
# Optional override tiny model for worthwhile-classifier stage
USER_MEMORY_TINY_MODEL_CLASSIFIER=
# Token threshold to trigger tiny-memory compaction
USER_MEMORY_TINY_ACCUMULATE_MAX_TOKENS=4000
# Max rolling Redis entries for memory pipeline audit
USER_MEMORY_AUDIT_MAX_ENTRIES=200
# Enable detailed memory classification logs
USER_MEMORY_DEBUG_CLASSIFICATION=False

# ================================
# LLM CALL AUDIT
# ================================
# Enable Redis audit entries for every LLM interaction
LLM_CALL_AUDIT_ENABLED=True
# Max rolling Redis entries per guild for LLM audit
LLM_CALL_AUDIT_MAX_ENTRIES=100

# ================================
# TOKEN STATS REPORTING
# ================================
# Channel ID for scheduled token reports
STATS_REPORT_CHANNEL_ID=
# Scheduled token report interval seconds
STATS_REPORT_INTERVAL_SECONDS=86400
# Number of top users to include in report
STATS_REPORT_TOP_USERS=10
